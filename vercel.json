{
  "version": 2,
  "toolbar": false,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/(auth|students|leaders|connections|overview|trends|at-risk|import|settings|admin|accounts|health)(/.*)?(\\?.*)?$",
      "dest": "/api/index.ts"
    },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
