PORT=4300
PERSISTENCE=memory
NODE_ENV=development
# Lock CORS to your domain(s) in production (comma-separated). If unset while
# NODE_ENV=production, the app defaults to https://ys-connection.vercel.app
# (never a wildcard). For local dev it defaults to '*'.
# CORS_ORIGINS=https://ys-connection.vercel.app
# For Supabase:
# PERSISTENCE=supabase
# DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# SESSION_SECRET=<random-32+-char-string>   # REQUIRED in production — signs session tokens
